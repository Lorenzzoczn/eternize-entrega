# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===== ASAAS CONFIGURATION =====
# Produção:
ASAAS_BASE_URL=https://api.asaas.com/v3
# Sandbox seria algo como:
# ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

ASAAS_API_KEY=SUA_CHAVE_ASAAS_AQUI

# ===== MERCADO PAGO CONFIGURATION (LEGADO - DESATIVADO) =====
# MERCADO_PAGO_ACCESS_TOKEN=SEU_ACCESS_TOKEN
# MERCADO_PAGO_PUBLIC_KEY=SUA_PUBLIC_KEY

# ===== SERVER CONFIGURATION =====
APP_URL=https://seu-dominio-ou-tunel.trycloudflare.com
NODE_ENV=development
PORT=3000

# ===== SECURITY =====
UPLOAD_RATE_LIMIT=50
GENERAL_RATE_LIMIT=100

# ===== FILE UPLOAD LIMITS =====
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=1

# ===== CORS SETTINGS =====
ALLOWED_ORIGINS=https://lorenzzoczn.github.io,https://seu-dominio-ou-tunel.trycloudflare.com

# ===== OPTIONAL FEATURES =====
ENABLE_ANALYTICS=true
ENABLE_COMPRESSION=true
ENABLE_LOGGING=true

# ===== DEPLOYMENT =====
DATABASE_URL=your-database-url-if-needed
REDIS_URL=your-redis-url-if-needed


# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===== MERCADO PAGO CONFIGURATION =====
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-your-access-token-here
MERCADO_PAGO_PUBLIC_KEY=APP_USR-your-public-key-here

# ===== SERVER CONFIGURATION =====
PORT=3000
NODE_ENV=production
APP_URL=https://eternize-v3.vercel.app

# ===== SECURITY =====
# Rate limiting
UPLOAD_RATE_LIMIT=50
GENERAL_RATE_LIMIT=100

# File upload limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=1

# ===== CORS SETTINGS =====
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ===== OPTIONAL FEATURES =====
# Enable/disable features
ENABLE_ANALYTICS=true
ENABLE_COMPRESSION=true
ENABLE_LOGGING=true

# ===== DEPLOYMENT =====
# For Railway, Render, or other platforms
DATABASE_URL=your-database-url-if-needed
REDIS_URL=your-redis-url-if-needed